# Neon (Source Database)
NEON_HOST=ep-xxxx.us-east-2.aws.neon.tech
NEON_DATABASE=neondb
NEON_USER=neondb_owner
NEON_PASSWORD=your_neon_password

# Streamkap Replication User
STREAMKAP_USER=streamkap_user
STREAMKAP_PASSWORD=your_strong_password_here

# MotherDuck (Destination)
MOTHERDUCK_TOKEN=md_your_access_token_here

# MotherDuck Postgres Endpoint (for Power BI)
MOTHERDUCK_PG_HOST=pg.us-east-1-aws.motherduck.com
MOTHERDUCK_PG_DATABASE=sales_analytics
